generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  operator
  customer
}

enum LocationType {
  island
  harbor
  airport
  city
  hotel
  attraction
  beach
  waterfall
}

enum TransferType {
  boat
  car
  boat_car
  private
  shared
  speed_boat
}

enum TripType {
  one_way
  return
}

enum PaymentStatus {
  pending
  paid
  failed
  expired
  refunded
}

enum BookingStatus {
  pending
  waiting_payment
  confirmed
  cancelled
  completed
  expired
}

enum PassengerType {
  adult
  child
  infant
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         UserRole  @default(customer)
  companyId    String?   @map("company_id")
  company      Company?  @relation(fields: [companyId], references: [id])
  bookings     Booking[]
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Location {
  id             String       @id @default(cuid())
  name           String
  slug           String       @unique
  type           LocationType
  region         String?
  description    String?      @db.Text
  image          String?
  gallery        String[]     @default([])
  latitude       Float?
  longitude      Float?
  isActive       Boolean      @default(true) @map("is_active")
  seoTitle       String?      @map("seo_title")
  seoDescription String?      @map("seo_description") @db.Text
  routesFrom     Route[]      @relation("FromLocation")
  routesTo       Route[]      @relation("ToLocation")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("locations")
}

model Route {
  id                String       @id @default(cuid())
  fromLocationId    String       @map("from_location_id")
  toLocationId      String       @map("to_location_id")
  fromLocation      Location     @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation        Location     @relation("ToLocation", fields: [toLocationId], references: [id])
  slug              String       @unique
  title             String
  description       String?      @db.Text
  estimatedDuration String?      @map("estimated_duration")
  transferType      TransferType @map("transfer_type")
  isReturnAvailable Boolean      @default(true) @map("is_return_available")
  isActive          Boolean      @default(true) @map("is_active")
  seoTitle          String?      @map("seo_title")
  seoDescription    String?      @map("seo_description") @db.Text
  services          Service[]
  bookings          Booking[]
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  @@map("routes")
}

model Company {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  logo         String?
  description  String?   @db.Text
  contactEmail String?   @map("contact_email")
  contactPhone String?   @map("contact_phone")
  address      String?
  rating       Float?    @default(0)
  isVerified   Boolean   @default(false) @map("is_verified")
  isActive     Boolean   @default(true) @map("is_active")
  users        User[]
  services     Service[]
  bookings     Booking[]
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("companies")
}

model Service {
  id                 String     @id @default(cuid())
  companyId          String     @map("company_id")
  routeId            String     @map("route_id")
  company            Company    @relation(fields: [companyId], references: [id])
  route              Route      @relation(fields: [routeId], references: [id])
  name               String
  description        String?    @db.Text
  serviceType        String?    @map("service_type")
  capacity           Int?
  basePrice          Float      @map("base_price")
  currency           String     @default("EUR")
  childPrice         Float?     @map("child_price")
  infantPrice        Float?     @map("infant_price")
  cancellationPolicy String?    @map("cancellation_policy") @db.Text
  notes              String?    @db.Text
  isActive           Boolean    @default(true) @map("is_active")
  schedules          Schedule[]
  prices             Price[]
  bookings           Booking[]
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  @@map("services")
}

model Schedule {
  id            String  @id @default(cuid())
  serviceId     String  @map("service_id")
  service       Service @relation(fields: [serviceId], references: [id])
  departureTime String  @map("departure_time")
  arrivalTime   String? @map("arrival_time")
  dayOfWeek     Int?    @map("day_of_week")
  isAvailable   Boolean @default(true) @map("is_available")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("schedules")
}

model Price {
  id         String   @id @default(cuid())
  serviceId  String   @map("service_id")
  service    Service  @relation(fields: [serviceId], references: [id])
  adultPrice Float    @map("adult_price")
  childPrice Float?   @map("child_price")
  infantPrice Float?  @map("infant_price")
  currency   String   @default("EUR")
  validFrom  DateTime? @map("valid_from")
  validUntil DateTime? @map("valid_until")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("prices")
}

model Booking {
  id            String        @id @default(cuid())
  bookingCode   String        @unique @map("booking_code")
  userId        String?       @map("user_id")
  serviceId     String        @map("service_id")
  routeId       String        @map("route_id")
  companyId     String        @map("company_id")
  user          User?         @relation(fields: [userId], references: [id])
  service       Service       @relation(fields: [serviceId], references: [id])
  route         Route         @relation(fields: [routeId], references: [id])
  company       Company       @relation(fields: [companyId], references: [id])
  tripType      TripType      @map("trip_type")
  departureDate DateTime      @map("departure_date")
  returnDate    DateTime?     @map("return_date")
  departureTime String        @map("departure_time")
  returnTime    String?       @map("return_time")
  adultsCount   Int           @map("adults_count")
  childrenCount Int           @default(0) @map("children_count")
  infantsCount  Int           @default(0) @map("infants_count")
  totalPrice    Float         @map("total_price")
  currency      String        @default("EUR")
  paymentStatus PaymentStatus @default(pending) @map("payment_status")
  bookingStatus BookingStatus @default(pending) @map("booking_status")
  customerName  String        @map("customer_name")
  customerEmail String        @map("customer_email")
  customerPhone String        @map("customer_phone")
  pickupPoint   String?       @map("pickup_point")
  dropoffPoint  String?       @map("dropoff_point")
  flightNumber  String?       @map("flight_number")
  specialRequest String?      @map("special_request") @db.Text
  expiresAt     DateTime?     @map("expires_at")
  passengers    Passenger[]
  payments      Payment[]
  tickets       Ticket[]
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@map("bookings")
}

model Passenger {
  id            String        @id @default(cuid())
  bookingId     String        @map("booking_id")
  booking       Booking       @relation(fields: [bookingId], references: [id])
  name          String
  passengerType PassengerType @map("passenger_type")
  createdAt     DateTime      @default(now()) @map("created_at")

  @@map("passengers")
}

model Payment {
  id                String        @id @default(cuid())
  bookingId         String        @map("booking_id")
  booking           Booking       @relation(fields: [bookingId], references: [id])
  provider          String
  providerReference String?       @map("provider_reference")
  amount            Float
  currency          String        @default("EUR")
  status            PaymentStatus @default(pending)
  paidAt            DateTime?     @map("paid_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@map("payments")
}

model Ticket {
  id         String   @id @default(cuid())
  bookingId  String   @map("booking_id")
  booking    Booking  @relation(fields: [bookingId], references: [id])
  ticketCode String   @unique @map("ticket_code")
  pdfUrl     String?  @map("pdf_url")
  sentAt     DateTime? @map("sent_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("tickets")
}

model Faq {
  id        String   @id @default(cuid())
  category  String?
  question  String
  answer    String   @db.Text
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("faqs")
}

model Page {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  content        String?  @db.Text
  template       String?
  seoTitle       String?  @map("seo_title")
  seoDescription String?  @map("seo_description") @db.Text
  isPublished    Boolean  @default(true) @map("is_published")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("pages")
}

model TravelTip {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  excerpt        String?  @db.Text
  content        String   @db.Text
  image          String?
  category       String   @default("Travel Tips")
  readTime       String?  @map("read_time")
  author         String?
  sortOrder      Int      @default(0) @map("sort_order")
  isPublished    Boolean  @default(true) @map("is_published")
  seoTitle       String?  @map("seo_title")
  seoDescription String?  @map("seo_description") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("travel_tips")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  userName  String?  @map("user_name")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  details   String?  @db.Text
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([entity, createdAt])
  @@index([userId])
  @@map("audit_logs")
}

model Review {
  id          String   @id @default(cuid())
  customerName String  @map("customer_name")
  country     String?
  rating      Int      @default(5)
  comment     String   @db.Text
  routeId     String?  @map("route_id")
  companyId   String?  @map("company_id")
  isApproved  Boolean  @default(false) @map("is_approved")
  isFeatured  Boolean  @default(false) @map("is_featured")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([isApproved, isFeatured])
  @@map("reviews")
}
