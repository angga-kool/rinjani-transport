# Database (PostgreSQL - Neon, Supabase, or Railway recommended for Vercel)
DATABASE_URL=postgresql://user:password@host:5432/rinjani_transport?sslmode=require

# NextAuth
NEXTAUTH_SECRET=your-random-secret-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://your-domain.vercel.app

# Email (optional - Resend recommended)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxx
SMTP_FROM=noreply@rinjanitransport.com

# Site
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
